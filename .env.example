# MUGON HR Bot - Environment Variables
# Copy to .env and fill in your credentials

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# OpenAI API Key
OPENAI_API_KEY=replace-with-openai-api-key

# AmoCRM Integration Settings
AMO_DOMAIN=eriarwork2201.amocrm.ru
AMO_CLIENT_ID=your-integration-client-id
AMO_CLIENT_SECRET=your-integration-client-secret
AMO_REDIRECT_URI=https://your-server.com/oauth
AMO_REFRESH_TOKEN=your-initial-refresh-token

# AmoCRM Pipeline Settings
AMO_PIPELINE_ID=10599910
AMO_STATUS_NEW=83583878

# Notifications: Telegram User IDs for CEO and PM
CEO_TG_ID=your-telegram-user-id
PM_TG_ID=pm-telegram-user-id

# Redis
REDIS_URL=redis://localhost:6379

# Public onboarding links
MUGON_CLUB_URL=https://t.me/MUGON_CLUB
MUGON_MEETUP_URL=https://meet.google.com/replace-with-current-meet-link
MUGON_MEETUP_AT=replace-with-current-date-and-time

# Safety: leave false while another provider owns the Telegram webhook.
ALLOW_WEBHOOK_REPLACEMENT=false
